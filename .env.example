# Nextcloud instance URL (no trailing slash)
NEXTCLOUD_URL=https://cloud.example.com

# Nextcloud login credentials (use an app password, not your main password)
NEXTCLOUD_USER=your-username
NEXTCLOUD_PASSWORD=your-app-password

# Path inside the container to the bind-mounted local folder
LOCAL_FOLDER=/sync

# Remote Nextcloud path to sync (use / for the root)
REMOTE_FOLDER=/
